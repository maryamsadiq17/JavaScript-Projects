{% comment %}
  ============================================================
  Section: Mid Promo Banner
  File:    sections/mid-promo-banner.liquid
  ============================================================
{% endcomment %}

<style>
  /* ==========================================================================
     6. MID-PAGE PROMO BANNER SECTION (PARALLAX EFFECT EDITION)
     ========================================================================== */
  #shopify-section-{{ section.id }} .mid-promo-banner {
      width: 100%;
      background-repeat: no-repeat;
      background-position: center center;
      background-size: auto;
      position: relative;
      overflow: hidden;
      padding: 110px 0;
  }

  #shopify-section-{{ section.id }} .mid-promo-container {
      position: relative;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 260px;
  }

  /* --- Centered Content Overlays --- */
  #shopify-section-{{ section.id }} .mid-promo-content {
      text-align: center;
      z-index: 5;
      max-width: 600px;
  }

  #shopify-section-{{ section.id }} .mid-promo-subtitle {
      font-size: 18px;
      font-weight: 300;
      color: #555555;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 12px;
  }

  #shopify-section-{{ section.id }} .mid-promo-heading {
      font-size: 54px;
      font-weight: 600;
      color: #222222;
      letter-spacing: 0.5px;
      line-height: 1.1;
      margin-bottom: 15px;
  }

  #shopify-section-{{ section.id }} .mid-promo-divider {
      width: 110px;
      height: 1px;
      background-color: #bbbbbb;
      margin: 0 auto 18px auto;
  }

  #shopify-section-{{ section.id }} .mid-promo-text {
      font-size: 16px;
      font-weight: 400;
      color: #666666;
      margin-bottom: 35px;
  }

  /* --- The Specialized Action Button --- */
  #shopify-section-{{ section.id }} .btn-promo-parallax {
      display: inline-block;
      background-color: var(--accent-color);
      color: var(--white);
      padding: 15px 48px;
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 1.5px;
      text-decoration: none;
      border: none;
      text-transform: uppercase;
      transition: background-color 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), color 0.3s ease;
  }

  #shopify-section-{{ section.id }} .btn-promo-parallax:hover {
      background-color: #333333;
      color: var(--white);
  }

  /* --- Responsive Performance Fallbacks --- */
  @media (max-width: 991px) {
      #shopify-section-{{ section.id }} .mid-promo-heading { font-size: 44px; }
      #shopify-section-{{ section.id }} .mid-promo-banner { background-attachment: scroll; }
  }
  @media (max-width: 480px) {
      #shopify-section-{{ section.id }} .mid-promo-heading { font-size: 34px; }
      #shopify-section-{{ section.id }} .mid-promo-banner { padding: 80px 0; }
  }
</style>

{%- liquid
  assign bg_image = section.settings.background_image
-%}

<section
  class="mid-promo-banner"
  {% if bg_image != blank %}
    style="background-image: url('{{ bg_image | image_url: width: 1920 }}');"
  {% endif %}
>
  <div class="container mid-promo-container">

    <div class="mid-promo-content">

      {% if section.settings.subtitle != blank %}
        <h5 class="mid-promo-subtitle">{{ section.settings.subtitle | escape }}</h5>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="mid-promo-heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      <div class="mid-promo-divider"></div>

      {% if section.settings.description != blank %}
        <p class="mid-promo-text">{{ section.settings.description | escape }}</p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_url | default: '#' }}"
          class="btn-promo-parallax"
        >
          {{ section.settings.button_label | escape }}
        </a>
      {% endif %}

    </div>

  </div>
</section>

{% schema %}
{
  "name": "Mid Promo Banner",
  "settings": [
    {
      "type": "header",
      "content": "Promo Imagery"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Banner Image",
      "info": "Recommended size: 1920×600px. Displays centered with auto sizing."
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle / Eyebrow Text",
      "default": "NEW TREND 2018",
      "info": "Displayed above the main heading in uppercase, lightweight style."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Women's Collection"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description / Promo Text",
      "default": "Big Sale of this Week"
    },
    {
      "type": "header",
      "content": "Call-to-Action Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button Link",
      "info": "Leave blank to default to '#'."
    }
  ],
  "presets": [
    {
      "name": "Mid Promo Banner"
    }
  ]
}
{% endschema %}

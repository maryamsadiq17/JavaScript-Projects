{% comment %}
  ============================================================
  Section: Newsletter Section
  File:    sections/newsletter-section.liquid
  ============================================================
{% endcomment %}

<style>
  /* ==========================================================================
     11. NEWSLETTER SUBSCRIPTION BAR
     ========================================================================== */
  #shopify-section-{{ section.id }} .newsletter-social-bar {
      background-color: {{ section.settings.background_color }};
      padding: 45px 0;
      {% if section.settings.background_image != blank %}
        background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');
        background-size: cover;
        background-position: center center;
        background-repeat: no-repeat;
      {% endif %}
  }

  #shopify-section-{{ section.id }} .newsletter-bar-grid {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 30px;
  }

  /* --- Column 1: Typography Configuration --- */
  #shopify-section-{{ section.id }} .newsletter-title-col h2 {
      font-size: 22px;
      font-weight: 600;
      color: #222222;
      letter-spacing: 0.2px;
      margin: 0;
  }

  /* --- Column 2: Inline Form Styling Elements --- */
  #shopify-section-{{ section.id }} .newsletter-form-col {
      flex-grow: 1;
      max-width: 550px;
  }

  #shopify-section-{{ section.id }} .newsletter-inline-form {
      display: flex;
      width: 100%;
  }

  #shopify-section-{{ section.id }} .newsletter-input {
      width: 100%;
      height: 48px;
      padding: 0 20px;
      background-color: #ffffff;
      border: 1px solid #e0e0e0;
      border-right: none;
      font-size: 14px;
      color: #333333;
      outline: none;
      transition: border-color 0.3s ease;
  }

  #shopify-section-{{ section.id }} .newsletter-input::placeholder {
      color: #b5b5b5;
  }

  #shopify-section-{{ section.id }} .newsletter-submit-btn {
      height: 48px;
      background-color: var(--accent-color);
      color: #ffffff;
      border: none;
      padding: 0 35px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 1px;
      cursor: pointer;
      white-space: nowrap;
      transition: background-color 0.3s ease;
  }

  #shopify-section-{{ section.id }} .newsletter-submit-btn:hover {
      background-color: #222222;
  }

  /* --- Success / Error Feedback Messages --- */
  #shopify-section-{{ section.id }} .newsletter-success-msg {
      font-size: 14px;
      font-weight: 600;
      color: #2e7d32;
      margin-top: 12px;
      text-align: center;
  }

  #shopify-section-{{ section.id }} .newsletter-error-msg {
      font-size: 13px;
      color: #c62828;
      margin-top: 10px;
      text-align: center;
  }

  /* --- Column 3: Social Platform Icon Grid Array --- */
  #shopify-section-{{ section.id }} .social-links-list {
      display: flex;
      align-items: center;
      gap: 22px;
      list-style: none;
      padding: 0;
      margin: 0;
  }

  #shopify-section-{{ section.id }} .social-links-list a {
      color: #222222;
      font-size: 16px;
      transition: color 0.3s ease;
      text-decoration: none;
  }

  #shopify-section-{{ section.id }} .social-links-list a:hover {
      color: var(--accent-color);
  }

  /* --- Responsive Adjustments --- */
  @media (max-width: 1199px) {
      #shopify-section-{{ section.id }} .newsletter-bar-grid {
          gap: 20px;
      }
      #shopify-section-{{ section.id }} .newsletter-title-col h2 {
          font-size: 19px;
      }
  }

  @media (max-width: 991px) {
      #shopify-section-{{ section.id }} .newsletter-bar-grid {
          flex-direction: column;
          text-align: center;
          gap: 25px;
      }
      #shopify-section-{{ section.id }} .newsletter-form-col {
          width: 100%;
      }
  }
</style>

<section class="newsletter-social-bar">
  <div class="container container-wide">
    <div class="newsletter-bar-grid">

      <!-- Column 1: Heading -->
      <div class="newsletter-title-col">
        {% if section.settings.heading != blank %}
          <h2>{{ section.settings.heading | escape }}</h2>
        {% endif %}
      </div>

      <!-- Column 2: Shopify Native Newsletter Form -->
      <div class="newsletter-form-col">

        {% form 'customer', class: 'newsletter-inline-form', id: 'newsletter-form-{{ section.id }}' %}

          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="hidden" name="contact[accepts_marketing]" value="true">

          <input
            type="email"
            name="contact[email]"
            id="newsletter-email-{{ section.id }}"
            class="newsletter-input"
            placeholder="{{ section.settings.input_placeholder | escape }}"
            required
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
          >

          <button type="submit" class="newsletter-submit-btn">
            {{ section.settings.button_label | escape }}
          </button>

        {% endform %}

        {% form 'customer' %}
          {% if form.posted_successfully? %}
            <p class="newsletter-success-msg">
              &#10003; Thank you for subscribing! We'll be in touch soon.
            </p>
          {% endif %}

          {% if form.errors %}
            <p class="newsletter-error-msg">
              {{ form.errors | default_errors }}
            </p>
          {% endif %}
        {% endform %}

      </div>

      <!-- Column 3: Social Icons -->
      <div class="newsletter-social-col">
        <ul class="social-links-list">

          {% if section.settings.social_facebook != blank %}
            <li>
              <a href="{{ section.settings.social_facebook }}" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
                <i class="fa-brands fa-facebook-f"></i>
              </a>
            </li>
          {% endif %}

          {% if section.settings.social_twitter != blank %}
            <li>
              <a href="{{ section.settings.social_twitter }}" aria-label="Twitter" target="_blank" rel="noopener noreferrer">
                <i class="fa-brands fa-twitter"></i>
              </a>
            </li>
          {% endif %}

          {% if section.settings.social_google != blank %}
            <li>
              <a href="{{ section.settings.social_google }}" aria-label="Google" target="_blank" rel="noopener noreferrer">
                <i class="fa-brands fa-google"></i>
              </a>
            </li>
          {% endif %}

          {% if section.settings.social_behance != blank %}
            <li>
              <a href="{{ section.settings.social_behance }}" aria-label="Behance" target="_blank" rel="noopener noreferrer">
                <i class="fa-brands fa-behance"></i>
              </a>
            </li>
          {% endif %}

          {% if section.settings.social_linkedin != blank %}
            <li>
              <a href="{{ section.settings.social_linkedin }}" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
                <i class="fa-brands fa-linkedin-in"></i>
              </a>
            </li>
          {% endif %}

        </ul>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter Section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sign up for Send Newsletter"
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Email Input Placeholder",
      "default": "Your Email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Submit Button Label",
      "default": "SUBSCRIBE"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f6f6f6"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "If set, the image overrides the background color. Recommended size: 1920×200px."
    },
    {
      "type": "header",
      "content": "Social Links"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter / X URL"
    },
    {
      "type": "url",
      "id": "social_google",
      "label": "Google URL"
    },
    {
      "type": "url",
      "id": "social_behance",
      "label": "Behance URL"
    },
    {
      "type": "url",
      "id": "social_linkedin",
      "label": "LinkedIn URL"
    }
  ],
  "presets": [
    {
      "name": "Newsletter Section",
      "settings": {
        "heading": "Sign up for Send Newsletter",
        "input_placeholder": "Your Email",
        "button_label": "SUBSCRIBE",
        "background_color": "#f6f6f6"
      }
    }
  ]
}
{% endschema %}

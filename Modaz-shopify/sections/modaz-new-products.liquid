  SCHEMA
══════════════════════════════════════════════════════════════{%- endcomment -%}
{% schema %}
{
  "name": "Modaz New Products",
  "tag": "div",
  "class": "mznp-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "📝 Section Heading"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "New Product"
    },
    {
      "type": "header",
      "content": "🎨 Colors"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#f63440",
      "info": "Used for price, ATC button, and title underline."
    },
    {
      "type": "color",
      "id": "accent_hover_color",
      "label": "Accent Hover / Darker Accent",
      "default": "#d6222d",
      "info": "ATC button hover state color."
    },
    {
      "type": "color",
      "id": "badge_new_color",
      "label": "'New' Badge Color",
      "default": "#7bc779"
    },
    {
      "type": "color",
      "id": "badge_sale_color",
      "label": "'Sale' Badge Color",
      "default": "#f63440"
    },
    {
      "type": "header",
      "content": "📐 Layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (Desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section Top & Bottom Padding (px)",
      "min": 20,
      "max": 160,
      "step": 10,
      "default": 80
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Product Image Box Height (px)",
      "min": 160,
      "max": 500,
      "step": 20,
      "default": 280
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "header",
          "content": "🛍 Product"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "The section reads the real title, price, images, and variants from this product automatically."
        },
        {
          "type": "header",
          "content": "🏷 Badge"
        },
        {
          "type": "text",
          "id": "badge_label",
          "label": "Badge Label",
          "info": "e.g. 'New', 'Sale', 'Hot'. Leave blank to auto-detect 'Sale' from compare-at price.",
          "default": "New"
        },
        {
          "type": "select",
          "id": "badge_type",
          "label": "Badge Color",
          "options": [
            { "value": "new",  "label": "Green (New)"   },
            { "value": "sale", "label": "Red (Sale)"    }
          ],
          "default": "new"
        },
        {
          "type": "header",
          "content": "❤️ Wishlist"
        },
        {
          "type": "checkbox",
          "id": "show_wishlist",
          "label": "Show Wishlist Button",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Modaz New Products",
      "category": "Products",
      "blocks": [
        { "type": "product_card", "settings": { "badge_label": "New",  "badge_type": "new",  "show_wishlist": true } },
        { "type": "product_card", "settings": { "badge_label": "New",  "badge_type": "new",  "show_wishlist": true } },
        { "type": "product_card", "settings": { "badge_label": "Sale", "badge_type": "sale", "show_wishlist": true } },
        { "type": "product_card", "settings": { "badge_label": "Sale", "badge_type": "sale", "show_wishlist": true } }
      ]
    }
  ]
}
{% endschema %}
